# ─── GitHub Copilot Chat — LLM Provider ─────────────────────────────────────
#
# Required for Phase 3 (LLM augmentation).
# Generate at: https://github.com/settings/tokens
# Scopes needed: read:user  (Copilot seat is enough — no extra scope required)
#
GITHUB_TOKEN=ghp_your_personal_access_token_here

# ─── Copilot Models ───────────────────────────────────────────────────────────
#
# COPILOT_MODEL      — used for code GENERATION (SQL transpilation, script conversion, expressions)
# COPILOT_REVIEWER_MODEL — used for the reviewer agent (always a stronger / smarter model)
#
# Verified available on the Copilot endpoint (as of mid-2026):
#   claude-haiku-4.5  — fast Anthropic model, good for generation          ← default
#   gpt-4o-mini       — fast OpenAI model, alternative for generation
#
# NOT available on the Copilot endpoint (as of mid-2026):
#   o4-mini, gpt-4.1-mini, o3-mini, gpt-4.5  — return 400 model_not_supported
#
# Run GET https://api.githubcopilot.com/models (see Postman collection) to see
# the full live list for your seat.
#
COPILOT_MODEL=claude-haiku-4.5
COPILOT_REVIEWER_MODEL=claude-haiku-4.5

# ─── Conversion Mode ─────────────────────────────────────────────────────────
#
# Controls which phases run when using `ssis-migrate convert` or `pipeline`.
#
#   deterministic  — Phase 1+2 only; never calls LLM; fast, no token cost
#   hybrid         — Phase 1+2 then LLM only for flagged items  ← default
#   llm            — Phase 1 then LLM for everything (ignores deterministic output)
#
CONVERSION_MODE=hybrid

# ─── LLM Pipeline tuning ─────────────────────────────────────────────────────
#
# Temperature for all code-generation calls (0.0–1.0).
# Lower = more deterministic output. 0.1 is recommended for code generation.
COPILOT_TEMPERATURE=0.1

# Max tokens per completion response.
COPILOT_MAX_TOKENS=4096

# Max review→regen iterations per component (each is one generation + one review call).
# On each failed review the generator is called again with the reviewer's issues as context.
COPILOT_MAX_REVIEW_ITERATIONS=4

# Max outer functional-validation passes per package.
# After all components convert, an LLM compares the full generated PySpark module
# against the original SSIS logic and flags mismatches; failing packages are
# re-converted with those mismatches as additional context.
FUNCTIONAL_VALIDATION_MAX_ITERATIONS=2

# Confidence threshold below which items are escalated to HUMAN_REVIEW.
# Range: 0.0–1.0. Default: 0.50
LLM_CONFIDENCE_THRESHOLD=0.50

# ─── Output ──────────────────────────────────────────────────────────────────
#
# Default output directory for generated .py files and reports.
OUTPUT_DIR=output

# Target PySpark version for API compatibility checks.
# Supported: 2.4, 3.3, 3.4, 3.5
SPARK_VERSION=3.3

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
